NEXT_PUBLIC_SITE_URL=https://descomplicalibras.shop

# Hoopay API (Basic Auth: username = CLIENT_ID, password = CLIENT_SECRET)
HOOPAY_CLIENT_ID=
HOOPAY_CLIENT_SECRET=
HOOPAY_API_URL=https://api.pay.hoopay.com.br

# Webhook auth — use um valor longo e aleatório (openssl rand -hex 32)
# A URL de callback inclui ?token=... automaticamente no checkout
HOOPAY_WEBHOOK_SECRET=

# Opcional — deixe vazio para usar checkout interno (/checkout/basico e /checkout/completo)
NEXT_PUBLIC_CHECKOUT_BASIC=
NEXT_PUBLIC_CHECKOUT_COMPLETE=

# Cartão de crédito (false = só PIX, reduz escopo PCI)
ENABLE_CREDIT_CARD=true

# Rate limit distribuído (recomendado em produção) — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
